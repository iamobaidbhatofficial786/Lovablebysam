# =========================================================================
# ByPass Ai Admin Dashboard Environment Variables Template
# Copy this file to '.env.local' and fill in your Supabase credentials.
# =========================================================================

# 1. Supabase Settings (Get these from Project Settings > API in Supabase dashboard)
# Your Supabase Project API URL (e.g., https://oijrtdrlacbajnyfinmv.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase publishable anonymous API key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase Service-Role key (CRITICAL: Private key used only on Vercel backend to manage licenses)
SUPABASE_SERVICE_ROLE_KEY=

# 2. Administrative Secrets
# A secure secret key used to sign and verify administrative session JWTs (change this to a secure random string)
ADMIN_SECRET=bypass-ai-secret-key-2026
